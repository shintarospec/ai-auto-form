"""
AI AutoForm - Auto Executor Service
automation_type='auto'のタスクを完全自動実行
"""

import time
import threading
from typing import Dict, Optional
from datetime import datetime
from backend.services.automation_service import FormAutomationService
from backend.database import get_db_session
from backend.simple_models import Task, Company, Product

# 設定定数
EXECUTION_TIMEOUT = 120  # タスク実行タイムアウト（秒）
MAX_RETRIES = 3  # 最大リトライ回数
RETRY_DELAY = 5  # リトライ間隔（秒）

# タスク実行ロック（重複実行防止）
_task_locks: Dict[int, threading.Lock] = {}
_lock_manager = threading.Lock()


def _get_task_lock(task_id: int) -> threading.Lock:
    """タスクIDごとのロックを取得（なければ作成）"""
    with _lock_manager:
        if task_id not in _task_locks:
            _task_locks[task_id] = threading.Lock()
        return _task_locks[task_id]


class AutoExecutor:
    """自動実行サービス（reCAPTCHA無しフォーム専用）"""
    
    def __init__(self, headless: bool = False, display: Optional[str] = ":1",
                 timeout: int = EXECUTION_TIMEOUT, max_retries: int = MAX_RETRIES):
        """
        初期化
        
        Args:
            headless: ヘッドレスモードで実行するか（False=VNC表示）
            display: DISPLAY環境変数（VNC使用時は ":1"）
            timeout: タスク実行タイムアウト（秒）
            max_retries: 最大リトライ回数
        """
        self.headless = headless
        self.display = display
        self.timeout = timeout
        self.max_retries = max_retries
        self.automation_service = None
        
    def execute_task(self, task_id: int) -> Dict:
        """
        タスクを自動実行（ロック機構・リトライ付き）
        
        Args:
            task_id: 実行するタスクID
            
        Returns:
            実行結果:
            {
                'success': bool,
                'task_id': int,
                'status': str,  # 'completed', 'failed'
                'execution_time': float,  # 秒
                'screenshots': list,  # スクリーンショットパス
                'error_message': Optional[str],
                'executed_at': str,
                'retry_count': int  # リトライ回数
            }
        """
        # ロック取得（重複実行防止）
        task_lock = _get_task_lock(task_id)
        if not task_lock.acquire(blocking=False):
            return {
                'success': False,
                'task_id': task_id,
                'status': 'locked',
                'execution_time': 0,
                'screenshots': [],
                'error_message': f'タスク {task_id} は現在実行中です',
                'executed_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
                'retry_count': 0
            }
        
        try:
            # リトライロジック
            last_error = None
            for retry_count in range(self.max_retries):
                if retry_count > 0:
                    print(f"🔄 リトライ {retry_count}/{self.max_retries}: Task#{task_id}")
                    time.sleep(RETRY_DELAY)
                
                result = self._execute_task_internal(task_id, retry_count)
                
                if result['success']:
                    return result
                
                last_error = result.get('error_message')
                
                # タイムアウトや致命的エラーはリトライしない
                if 'タイムアウト' in str(last_error) or '対象外' in str(last_error):
                    break
            
            # 全リトライ失敗
            result['error_message'] = f"全{self.max_retries}回のリトライ失敗: {last_error}"
            return result
            
        finally:
            task_lock.release()
    
    def _execute_task_internal(self, task_id: int, retry_count: int = 0) -> Dict:
        """タスク実行の内部処理"""
        start_time = time.time()
        result = {
            'success': False,
            'task_id': task_id,
            'status': 'failed',
            'execution_time': 0,
            'screenshots': [],
            'error_message': None,
            'executed_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            'retry_count': retry_count
        }
        
        db = None
        try:
            # タイムアウトチェック用
            deadline = start_time + self.timeout
            
            # DB接続
            db = get_db_session()
            
            # タスク情報取得（JOIN）
            task = db.query(Task).filter(Task.id == task_id).first()
            if not task:
                raise ValueError(f"タスクID {task_id} が見つかりません")
            
            company = db.query(Company).filter(Company.id == task.company_id).first()
            product = db.query(Product).filter(Product.id == task.product_id).first()
            
            if not company or not product:
                raise ValueError("企業または案件が見つかりません")
            
            print(f"🤖 自動実行開始: Task#{task_id} | {company.name} | {company.form_url}")
            
            # automation_type検証
            if task.automation_type != 'auto':
                raise ValueError(f"このタスクは自動実行対象外です (automation_type={task.automation_type})")
            
            # reCAPTCHA検証
            if task.recaptcha_type == 'v2':
                raise ValueError("reCAPTCHA v2が検出されているため自動実行できません")
            
            # タスクステータス更新: pending → processing
            task.status = 'processing'
            db.commit()
            
            # フォーム入力データ準備
            form_data = {
                'company': product.sender_company or company.name,
                'name': product.sender_name or '営業担当',
                'email': product.sender_email or 'info@example.com',
                'phone': product.sender_phone or '03-0000-0000',
                'message': f"{product.name}に関するお問い合わせ\n\n詳細をお聞かせいただけますでしょうか。"
            }
            
            print(f"📝 入力データ: company={form_data['company']}, name={form_data['name']}")
            
            # AutomationService起動
            self.automation_service = FormAutomationService(
                headless=self.headless,
                display=self.display
            )
            self.automation_service.start()
            
            try:
                # タイムアウトチェック
                if time.time() > deadline:
                    raise TimeoutError(f"タイムアウト: {self.timeout}秒を超過しました")
                
                # フォーム自動入力実行
                automation_result = self.automation_service.fill_contact_form(
                    form_url=company.form_url,
                    message_data=form_data,
                    wait_for_captcha=False  # auto-executeはreCAPTCHA無し前提
                )
                
                # タイムアウトチェック
                if time.time() > deadline:
                    raise TimeoutError(f"タイムアウト: {self.timeout}秒を超過しました")
                
                if automation_result.get('success'):
                    # 成功
                    result['success'] = True
                    result['status'] = 'completed'
                    result['screenshots'] = automation_result.get('screenshots', [])
                    
                    # タスクステータス更新: processing → completed
                    task.status = 'completed'
                    task.completed_at = datetime.now()
                    db.commit()
                    
                    print(f"✅ 自動実行完了: Task#{task_id}")
                else:
                    # 失敗
                    error_msg = automation_result.get('error', 'フォーム入力失敗')
                    result['error_message'] = error_msg
                    result['screenshots'] = automation_result.get('screenshots', [])
                    
                    # リトライ可能な場合はステータスをpendingに戻す
                    if retry_count < self.max_retries - 1:
                        task.status = 'pending'
                    else:
                        task.status = 'failed'
                    db.commit()
                    
                    print(f"❌ 自動実行失敗: Task#{task_id} - {error_msg}")
                    
            finally:
                # ブラウザクリーンアップ
                self.automation_service.stop()
            
        except TimeoutError as e:
            result['error_message'] = str(e)
            print(f"⏰ タイムアウト: Task#{task_id} - {e}")
            
            # タイムアウト時はステータスをfailedに
            if db:
                try:
                    task = db.query(Task).filter(Task.id == task_id).first()
                    if task:
                        task.status = 'failed'
                        db.commit()
                except:
                    pass
                    
        except Exception as e:
            result['error_message'] = str(e)
            print(f"❌ 自動実行エラー: Task#{task_id} - {e}")
            
            # エラー時もステータス更新（リトライ可能ならpending）
            if db:
                try:
                    task = db.query(Task).filter(Task.id == task_id).first()
                    if task:
                        if retry_count < self.max_retries - 1:
                            task.status = 'pending'
                        else:
                            task.status = 'failed'
                        db.commit()
                except:
                    pass
        finally:
            if db:
                db.close()
            
            result['execution_time'] = time.time() - start_time
            
        return result
    
    def execute_batch(self, company_id: int, limit: int = 10) -> Dict:
        """
        企業の自動実行可能タスクを一括実行
        
        Args:
            company_id: 企業ID
            limit: 最大実行件数
            
        Returns:
            実行結果:
            {
                'success': bool,
                'company_id': int,
                'total_tasks': int,
                'completed': int,
                'failed': int,
                'results': list,  # 各タスクの実行結果
                'execution_time': float
            }
        """
        start_time = time.time()
        result = {
            'success': False,
            'company_id': company_id,
            'total_tasks': 0,
            'completed': 0,
            'failed': 0,
            'results': [],
            'execution_time': 0
        }
        
        db = None
        try:
            # 自動実行可能タスク取得
            db = get_db_session()
            
            tasks = db.query(Task).filter(
                Task.company_id == company_id,
                Task.automation_type == 'auto',
                Task.status == 'pending'
            ).order_by(Task.id).limit(limit).all()
            
            task_ids = [task.id for task in tasks]
            result['total_tasks'] = len(task_ids)
            
            if not task_ids:
                result['success'] = True
                print(f"ℹ️ 企業ID {company_id} に自動実行可能タスクがありません")
                db.close()
                return result
            
            print(f"🤖 バッチ実行開始: 企業ID {company_id} | {len(task_ids)}タスク")
            
            # DB接続をクローズ（各タスク実行で新規接続）
            db.close()
            db = None
            
            # 各タスクを順次実行
            for task_id in task_ids:
                task_result = self.execute_task(task_id)
                result['results'].append(task_result)
                
                if task_result['success']:
                    result['completed'] += 1
                else:
                    result['failed'] += 1
                
                # タスク間にインターバル（サーバー負荷軽減）
                time.sleep(2)
            
            result['success'] = True
            print(f"✅ バッチ実行完了: 完了={result['completed']}, 失敗={result['failed']}")
            
        except Exception as e:
            result['error_message'] = str(e)
            print(f"❌ バッチ実行エラー: 企業ID {company_id} - {e}")
        finally:
            if db:
                db.close()
            
            result['execution_time'] = time.time() - start_time
            
        return result


def execute_task_sync(task_id: int, headless: bool = False, display: str = ":1") -> Dict:
    """
    同期的にタスクを自動実行（Flask用ラッパー）
    
    Args:
        task_id: タスクID
        headless: ヘッドレスモード
        display: DISPLAY環境変数
        
    Returns:
        実行結果辞書
    """
    executor = AutoExecutor(headless=headless, display=display)
    return executor.execute_task(task_id)


def execute_batch_sync(company_id: int, limit: int = 10, headless: bool = False, display: str = ":1") -> Dict:
    """
    同期的にバッチ実行（Flask用ラッパー）
    
    Args:
        company_id: 企業ID
        limit: 最大実行件数
        headless: ヘッドレスモード
        display: DISPLAY環境変数
        
    Returns:
        実行結果辞書
    """
    executor = AutoExecutor(headless=headless, display=display)
    return executor.execute_batch(company_id, limit)
